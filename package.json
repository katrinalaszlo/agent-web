{
  "name": "aeo-ready",
  "version": "1.3.1",
  "description": "AEO benchmark aggregator. One scan, every score. Collects agentic-seo, Cloudflare, and Fern in one report.",
  "type": "module",
  "bin": {
    "aeo-ready": "./bin/cli.js"
  },
  "main": "./src/index.js",
  "scripts": {
    "start": "node bin/cli.js",
    "test": "node --test src/**/*.test.js"
  },
  "keywords": [
    "aeo",
    "ai",
    "agent",
    "seo",
    "llms-txt",
    "agents-json",
    "ai-visibility",
    "agent-readiness",
    "structured-data",
    "schema-org"
  ],
  "author": "Kat Laszlo <kat@tansohq.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/katrinalaszlo/aeo-ready.git"
  },
  "homepage": "https://github.com/katrinalaszlo/aeo-ready#readme",
  "bugs": {
    "url": "https://github.com/katrinalaszlo/aeo-ready/issues"
  },
  "files": [
    "bin/",
    "src/benchmark/",
    "src/history/",
    "src/utils/",
    "src/index.js",
    "src/scan.js",
    "skills/",
    "README.md",
    "CHANGELOG.md"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "afdocs": "^0.18.7",
    "chalk": "^5.3.0",
    "commander": "^12.0.0"
  }
